{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "EventManagement",
    "Audience": "EventManagement",
    "AccessTokenExpiryMinutes": 30,
    "RefreshTokenExpiryDays": 7
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 25,
    "UseSsl": false,
    "FromEmail": "noreply@eventplatform.com",
    "FromName": "Event Platform"
  },
  "Cookie": {
    "SameSite": "Strict"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:4200"
  },
  "AllowedOrigins": [
    "http://localhost:4200"
  ],
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=eventmanagement;User=root;Password=root;"
  },
  "AllowedHosts": "*"
}
